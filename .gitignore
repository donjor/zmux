# Pi extension local deps (peerDeps model — lockfile is dev-install noise, not tracked)
# No trailing slash: node_modules is a symlink to shared deps, and a dir-only
# pattern (trailing slash) would skip the symlink, leaving it untracked-visible.
/pi-extension/node_modules
/pi-extension/package-lock.json

# v0 downloaded theme cache (if v0 init is ever run)
legacy/v0/themes/iterm2/

skills/zmux/reports

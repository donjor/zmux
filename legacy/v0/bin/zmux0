#!/usr/bin/env bash
# ╔══════════════════════════════════════════╗
# ║  zmux — tmux session controller          ║
# ║  powered by charmbracelet/gum            ║
# ╚══════════════════════════════════════════╝

ZMUX_VERSION="0.1.0"
ZMUX_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# ── Load shared theme library ──
source "$ZMUX_ROOT/lib/theme.sh"
zmux_load_config
zmux_load_theme

# ── Helpers ──
header()  { $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" "  $1"; }
subtext() { $GUM style --foreground "$ZMUX_MUTED" --margin "0 2" "  $1"; }
success() { $GUM style --foreground "$ZMUX_SUCCESS" --bold --margin "0 2" "  ✓ $1"; }
fail()    { $GUM style --foreground "$ZMUX_ERROR" --margin "0 2" "  ✗ $1"; }

cleanup_tmp() {
    for s in $(tmux list-sessions -F '#{session_name}:#{session_attached}' 2>/dev/null | grep ':0$' | grep '^tmp-' | cut -d: -f1); do
        tmux kill-session -t "$s" 2>/dev/null
    done
}

extract_name() {
    echo "$1" | sed 's/^[●○◆] //' | awk -F'  ' '{print $1}' | xargs
}

human_age() {
    local now=$(date +%s)
    local age_s=$((now - $1))
    if (( age_s < 60 )); then echo "${age_s}s"
    elif (( age_s < 3600 )); then echo "$((age_s / 60))m"
    elif (( age_s < 86400 )); then echo "$((age_s / 3600))h"
    else echo "$((age_s / 86400))d"; fi
}

# ── Render compact session line ──
render_session_line() {
    local name="$1" is_current="$2"

    local win_count=$(tmux list-windows -t "$name" 2>/dev/null | wc -l)
    local attached=$(tmux display-message -t "$name" -p '#{session_attached}' 2>/dev/null)
    local activity=$(tmux display-message -t "$name" -p '#{session_activity}' 2>/dev/null)
    local dir=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null)
    dir="${dir/#$HOME/~}"
    [[ ${#dir} -gt 20 ]] && dir="…${dir: -19}"
    local age=$(human_age "$activity")

    local name_color="$ZMUX_MUTED" icon="○"
    if [[ "$is_current" == "true" ]]; then
        name_color="$ZMUX_ACCENT"; icon="◆"
    elif [[ "$attached" == "1" ]]; then
        name_color="$ZMUX_INFO"; icon="●"
    fi

    # Tab names inline
    local tabs=$(tmux list-windows -t "$name" -F '#{window_name}' 2>/dev/null | tr '\n' ' ')

    printf "%s %s  %s  %s  %s" \
        "$($GUM style --foreground "$name_color" "$icon")" \
        "$($GUM style --foreground "$name_color" --bold "$(printf '%-12s' "$name")")" \
        "$($GUM style --foreground "$ZMUX_DIM" "${win_count}w")" \
        "$($GUM style --foreground "$ZMUX_DIM" "$dir")" \
        "$($GUM style --foreground "$ZMUX_DIM" --faint "${age}")"
}

# ══════════════════════════════════════════
# ACTIONS
# ══════════════════════════════════════════

action_new_session() {
    local name=$($GUM input \
        --placeholder "blank for tmp" \
        --prompt "  name ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --cursor.foreground "$ZMUX_INFO" \
        --width 40)

    if [[ -z "$name" ]]; then
        local n=1
        while tmux has-session -t "tmp-$n" 2>/dev/null; do ((n++)); done
        name="tmp-$n"
    fi

    if tmux has-session -t "$name" 2>/dev/null; then
        fail "session '$name' already exists"
        return 1
    fi

    local dir=$($GUM file --directory --height 8 --cursor.foreground "$ZMUX_ACCENT" "$HOME" 2>/dev/null)
    [[ -z "$dir" ]] && dir="$HOME"

    if [[ -n "$TMUX" ]]; then
        tmux new-session -d -s "$name" -c "$dir"
        tmux switch-client -t "$name"
    else
        exec tmux new-session -s "$name" -c "$dir"
    fi
}

action_new_from_template() {
    local templates=()
    if [[ -d "$TEMPLATES_DIR" ]]; then
        for f in "$TEMPLATES_DIR"/*.sh; do
            [[ -f "$f" ]] || continue
            local tname=$(basename "$f" .sh)
            local desc=$(head -2 "$f" | grep '^# ' | tail -1 | sed 's/^# //')
            templates+=("$tname  —  $desc")
        done
    fi

    if [[ ${#templates[@]} -eq 0 ]]; then
        fail "no templates in $TEMPLATES_DIR"
        return 1
    fi

    local picked=$($GUM choose \
        --cursor "  ▸ " \
        --cursor.foreground "$ZMUX_ACCENT" \
        --selected.foreground "$ZMUX_INFO" \
        --item.foreground "$ZMUX_MUTED" \
        --header "  template:" \
        --header.foreground "$ZMUX_ACCENT" \
        "${templates[@]}")

    [[ -z "$picked" ]] && return 0

    local tname=$(echo "$picked" | awk '{print $1}')

    local name=$($GUM input \
        --value "$tname" \
        --prompt "  session name ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --cursor.foreground "$ZMUX_INFO" \
        --width 40)
    [[ -z "$name" ]] && name="$tname"

    if tmux has-session -t "$name" 2>/dev/null; then
        fail "session '$name' already exists"
        return 1
    fi

    local dir=$($GUM file --directory --height 8 --cursor.foreground "$ZMUX_ACCENT" "$HOME" 2>/dev/null)
    [[ -z "$dir" ]] && dir="$HOME"

    export ZMUX_SESSION="$name"
    export ZMUX_DIR="$dir"
    bash "$TEMPLATES_DIR/${tname}.sh"

    if [[ -n "$TMUX" ]]; then
        tmux switch-client -t "$name"
    else
        exec tmux attach -t "$name"
    fi
}

action_switch() {
    cleanup_tmp
    local sessions=()
    local targets=()

    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        local wins=$(echo "$line" | cut -d'|' -f2)
        local attached=$(echo "$line" | cut -d'|' -f3)
        local activity=$(echo "$line" | cut -d'|' -f4)

        local icon="○" age=$(human_age "$activity")
        [[ "$attached" == "1" ]] && icon="●"

        local win_names=$(tmux list-windows -t "$name" -F '#{window_name}' 2>/dev/null | tr '\n' ',' | sed 's/,$//')

        sessions+=("$icon $name  ${wins}w [$win_names]  ${age}")
        targets+=("$name")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}|#{session_activity}' 2>/dev/null | sort)

    if [[ ${#sessions[@]} -eq 0 ]]; then
        subtext "no sessions"
        return 1
    fi

    local picked=$($GUM filter \
        --placeholder "search sessions..." \
        --prompt "  ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --indicator.foreground "$ZMUX_ACCENT" \
        --match.foreground "$ZMUX_INFO" \
        --text.foreground "$ZMUX_FG" \
        --header "  switch to:" \
        --header.foreground "$ZMUX_ACCENT" \
        --height $((${#sessions[@]} + 2)) \
        "${sessions[@]}")

    [[ -z "$picked" ]] && return 0

    local name=$(echo "$picked" | sed 's/^[●○] //' | awk '{print $1}')

    if [[ -n "$TMUX" ]]; then
        tmux switch-client -t "$name"
    else
        exec tmux attach -t "$name"
    fi
}

action_move_tab() {
    [[ -z "$TMUX" ]] && { fail "not in tmux"; return 1; }

    local current=$(tmux display-message -p '#S')
    local current_win=$(tmux display-message -p '#W')

    local targets=("+ create new session")
    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        local wins=$(echo "$line" | cut -d'|' -f2)
        [[ "$name" == "$current" ]] && continue
        targets+=("$name  (${wins}w)")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort)

    local picked=$($GUM filter \
        --placeholder "move '$current_win' to..." \
        --prompt "  ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --match.foreground "$ZMUX_INFO" \
        --text.foreground "$ZMUX_FG" \
        --header "  move tab → session:" \
        --header.foreground "$ZMUX_ACCENT" \
        --height $((${#targets[@]} + 2)) \
        "${targets[@]}")

    [[ -z "$picked" ]] && return 0

    if [[ "$picked" == *"create new"* ]]; then
        local name=$($GUM input \
            --placeholder "session name" \
            --prompt "  name ▸ " \
            --prompt.foreground "$ZMUX_ACCENT" \
            --cursor.foreground "$ZMUX_INFO" \
            --width 40)
        [[ -z "$name" ]] && return 0

        tmux new-session -d -s "$name"
        local default_win=$(tmux list-windows -t "$name" -F '#{window_id}' | head -1)
        tmux move-window -a -t "$name"
        tmux kill-window -t "$default_win" 2>/dev/null
        tmux switch-client -t "$name"
    else
        local name=$(echo "$picked" | awk '{print $1}')
        tmux move-window -a -t "$name"
        tmux switch-client -t "$name"
    fi
}

action_rename_session() {
    [[ -z "$TMUX" ]] && { fail "not in tmux"; return 1; }
    local current=$(tmux display-message -p '#S')
    local name=$($GUM input --value "$current" \
        --prompt "  rename session ▸ " --prompt.foreground "$ZMUX_ACCENT" \
        --cursor.foreground "$ZMUX_INFO" --width 40)
    [[ -z "$name" || "$name" == "$current" ]] && return 0
    tmux rename-session "$name"
    success "renamed → $name"
}

action_rename_tab() {
    [[ -z "$TMUX" ]] && { fail "not in tmux"; return 1; }
    local current=$(tmux display-message -p '#W')
    local name=$($GUM input --value "$current" \
        --prompt "  rename tab ▸ " --prompt.foreground "$ZMUX_INFO" \
        --cursor.foreground "$ZMUX_INFO" --width 40)
    [[ -z "$name" || "$name" == "$current" ]] && return 0
    tmux rename-window "$name"
    success "tab → $name"
}

action_kill_session() {
    local sessions=()
    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        local wins=$(echo "$line" | cut -d'|' -f2)
        local attached=$(echo "$line" | cut -d'|' -f3)
        local icon="○"
        [[ "$attached" == "1" ]] && icon="●"
        sessions+=("$icon $name  (${wins}w)")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}' 2>/dev/null | sort)

    [[ ${#sessions[@]} -eq 0 ]] && { subtext "no sessions"; return 1; }

    local picked=$($GUM filter \
        --placeholder "kill..." \
        --prompt "  ▸ " --prompt.foreground "$ZMUX_ERROR" \
        --match.foreground "$ZMUX_ERROR" --text.foreground "$ZMUX_FG" \
        --header "  kill session:" --header.foreground "$ZMUX_ERROR" \
        --height $((${#sessions[@]} + 2)) \
        "${sessions[@]}")

    [[ -z "$picked" ]] && return 0
    local name=$(echo "$picked" | sed 's/^[●○] //' | awk '{print $1}')

    if $GUM confirm --selected.background "$ZMUX_ERROR" --selected.foreground "$ZMUX_BG" \
        --unselected.background "$ZMUX_SURFACE" --unselected.foreground "$ZMUX_MUTED" \
        "  kill '$name'?"; then
        tmux kill-session -t "$name"
        success "killed $name"
    fi
}

action_kill_tab() {
    [[ -z "$TMUX" ]] && { fail "not in tmux"; return 1; }
    local wins=()
    while IFS= read -r line; do wins+=("$line"); done \
        < <(tmux list-windows -F '#I: #W  (#{pane_current_command})' 2>/dev/null)

    [[ ${#wins[@]} -le 1 ]] && { subtext "only one tab — use kill session"; return 1; }

    local picked=$($GUM choose --cursor "  ▸ " --cursor.foreground "$ZMUX_ERROR" \
        --selected.foreground "$ZMUX_ERROR" --item.foreground "$ZMUX_MUTED" \
        --header "  kill tab:" --header.foreground "$ZMUX_ERROR" "${wins[@]}")
    [[ -z "$picked" ]] && return 0

    tmux kill-window -t "$(echo "$picked" | cut -d: -f1)"
    success "killed tab"
}

action_preview() {
    local sessions=()
    local names=()
    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        local wins=$(echo "$line" | cut -d'|' -f2)
        sessions+=("$name  (${wins}w)")
        names+=("$name")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort)

    [[ ${#sessions[@]} -eq 0 ]] && { subtext "no sessions"; return 1; }

    local picked=$($GUM choose --cursor "  ▸ " --cursor.foreground "$ZMUX_ACCENT" \
        --selected.foreground "$ZMUX_INFO" --item.foreground "$ZMUX_MUTED" \
        --header "  preview:" --header.foreground "$ZMUX_ACCENT" "${sessions[@]}")
    [[ -z "$picked" ]] && return 0

    local name=$(echo "$picked" | awk '{print $1}')
    local content=$(tmux capture-pane -t "$name" -p -S -30 2>/dev/null)
    local wins=$(tmux list-windows -t "$name" -F '  #I: #W (#{pane_current_command})' 2>/dev/null)
    local dir=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null)
    dir="${dir/#$HOME/~}"

    $GUM style \
        --border rounded --border-foreground "$ZMUX_DIM" \
        --padding "1 2" --width 70 --foreground "$ZMUX_FG" \
        "$($GUM style --foreground "$ZMUX_ACCENT" --bold "$name")  $($GUM style --foreground "$ZMUX_MUTED" "$dir")" \
        "" \
        "$($GUM style --foreground "$ZMUX_INFO" --bold "tabs:")" \
        "$wins" \
        "" \
        "$($GUM style --foreground "$ZMUX_INFO" --bold "output:")" \
        "$(echo "$content" | tail -15)" | $GUM pager --soft-wrap
}

# ══════════════════════════════════════════
# THEME BROWSER
# ══════════════════════════════════════════
_theme_swatch() {
    local name="$1"
    # Temporarily load the theme to get its colors
    local save_bg="$ZMUX_BG" save_fg="$ZMUX_FG" save_surface="$ZMUX_SURFACE"
    local save_error="$ZMUX_ERROR" save_success="$ZMUX_SUCCESS" save_accent="$ZMUX_ACCENT"
    local save_info="$ZMUX_INFO" save_special="$ZMUX_SPECIAL" save_meta="$ZMUX_META"
    local save_muted="$ZMUX_MUTED" save_dim="$ZMUX_DIM" save_highlight="$ZMUX_HIGHLIGHT"
    local save_name="$ZMUX_THEME_NAME" save_file="$ZMUX_THEME_FILE"

    ZMUX_THEME_NAME="$name"
    zmux_load_theme

    local r=$'\033[0m'
    local b=$'\033[1m'
    printf "\n"
    printf "  %s%s %s%s\n" "$b" "$(zmux_ansi "$ZMUX_ACCENT")$name" "$r" ""

    # Color blocks — each is a filled block with the color
    local block="██"
    printf "  "
    printf "$(zmux_ansi "$ZMUX_BG")${block} "
    printf "$(zmux_ansi "$ZMUX_SURFACE")${block} "
    printf "$(zmux_ansi "$ZMUX_DIM")${block} "
    printf "$(zmux_ansi "$ZMUX_MUTED")${block} "
    printf "$(zmux_ansi "$ZMUX_FG")${block} "
    printf "$(zmux_ansi "$ZMUX_ERROR")${block} "
    printf "$(zmux_ansi "$ZMUX_SUCCESS")${block} "
    printf "$(zmux_ansi "$ZMUX_ACCENT")${block} "
    printf "$(zmux_ansi "$ZMUX_INFO")${block} "
    printf "$(zmux_ansi "$ZMUX_SPECIAL")${block} "
    printf "$(zmux_ansi "$ZMUX_META")${block} "
    printf "$(zmux_ansi "$ZMUX_HIGHLIGHT")${block}"
    printf "${r}\n"

    # Labels
    printf "  $(zmux_ansi "$ZMUX_DIM")"
    printf "bg  sur dim mut fg  err ok  acc inf spc met hlt"
    printf "${r}\n"

    # Restore original theme
    ZMUX_BG="$save_bg" ZMUX_FG="$save_fg" ZMUX_SURFACE="$save_surface"
    ZMUX_ERROR="$save_error" ZMUX_SUCCESS="$save_success" ZMUX_ACCENT="$save_accent"
    ZMUX_INFO="$save_info" ZMUX_SPECIAL="$save_special" ZMUX_META="$save_meta"
    ZMUX_MUTED="$save_muted" ZMUX_DIM="$save_dim" ZMUX_HIGHLIGHT="$save_highlight"
    ZMUX_THEME_NAME="$save_name" ZMUX_THEME_FILE="$save_file"
}

action_theme() {
    local themes=()
    local current_theme="$ZMUX_THEME_NAME"

    # Scan zmux theme dirs
    local -A seen
    local source_label=""

    # Bundled themes
    if [[ -d "$ZMUX_ROOT/themes/bundled" ]]; then
        for f in "$ZMUX_ROOT/themes/bundled"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            seen["$name"]=1
            local marker="  "
            [[ "$name" == "$current_theme" ]] && marker="● "
            themes+=("${marker}${name}")
        done
    fi

    # User custom themes
    if [[ -d "${HOME}/.zmux/themes" ]]; then
        for f in "${HOME}/.zmux/themes"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            [[ -n "${seen[$name]}" ]] && continue
            seen["$name"]=1
            local marker="  "
            [[ "$name" == "$current_theme" ]] && marker="● "
            themes+=("${marker}${name}")
        done
    fi

    # Downloaded iterm2 themes
    if [[ -d "$ZMUX_ROOT/themes/iterm2" ]]; then
        for f in "$ZMUX_ROOT/themes/iterm2"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            [[ -n "${seen[$name]}" ]] && continue

            # Only dark themes (background R < 64)
            local bg=$(grep '^background' "$f" 2>/dev/null | head -1 | awk '{print $NF}')
            [[ -z "$bg" ]] && continue
            local r_hex="${bg:1:2}"
            local r=$((16#$r_hex))
            (( r > 64 )) && continue

            seen["$name"]=1
            local marker="  "
            [[ "$name" == "$current_theme" ]] && marker="● "
            themes+=("${marker}${name}")
        done
    fi

    if [[ ${#themes[@]} -eq 0 ]]; then
        fail "no themes found"
        return 1
    fi

    local picked=$($GUM filter \
        --placeholder "search themes..." \
        --prompt "  ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --indicator.foreground "$ZMUX_ACCENT" \
        --match.foreground "$ZMUX_INFO" \
        --text.foreground "$ZMUX_FG" \
        --header "  theme: $current_theme" \
        --header.foreground "$ZMUX_ACCENT" \
        --height 15 \
        "${themes[@]}")

    [[ -z "$picked" ]] && return 0

    local new_theme=$(echo "$picked" | sed 's/^[● ] *//')

    # Verify theme exists
    if ! zmux_resolve_theme "$new_theme"; then
        fail "theme '$new_theme' not found"
        return 1
    fi

    # Show preview
    _theme_swatch "$new_theme"

    if ! $GUM confirm \
        --selected.background "$ZMUX_ACCENT" --selected.foreground "$ZMUX_BG" \
        --unselected.background "$ZMUX_SURFACE" --unselected.foreground "$ZMUX_MUTED" \
        "  apply '$new_theme'?"; then
        return 0
    fi

    # Update config and apply
    source "$ZMUX_ROOT/lib/sync.sh"
    _zmux_set_theme "$new_theme"
    success "theme → $new_theme"
}

action_theme_set() {
    local name="$1"
    [[ -z "$name" ]] && { fail "usage: zmux theme set <name>"; return 1; }

    if ! zmux_resolve_theme "$name"; then
        fail "theme '$name' not found"
        return 1
    fi

    source "$ZMUX_ROOT/lib/sync.sh"
    _zmux_set_theme "$name"
    success "theme → $name"
}

action_theme_list() {
    local -A seen

    # Bundled
    if [[ -d "$ZMUX_ROOT/themes/bundled" ]]; then
        $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" "bundled"
        for f in "$ZMUX_ROOT/themes/bundled"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            seen["$name"]=1
            local marker="  "
            [[ "$name" == "$ZMUX_THEME_NAME" ]] && marker="● "
            printf "  %s%s\n" "$marker" "$name"
        done
    fi

    # User
    if [[ -d "${HOME}/.zmux/themes" ]] && [[ -n "$(ls -A "${HOME}/.zmux/themes" 2>/dev/null)" ]]; then
        printf "\n"
        $GUM style --foreground "$ZMUX_SPECIAL" --bold --margin "0 2" "custom"
        for f in "${HOME}/.zmux/themes"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            [[ -n "${seen[$name]}" ]] && continue
            seen["$name"]=1
            local marker="  "
            [[ "$name" == "$ZMUX_THEME_NAME" ]] && marker="● "
            printf "  %s%s\n" "$marker" "$name"
        done
    fi

    # iterm2
    if [[ -d "$ZMUX_ROOT/themes/iterm2" ]] && [[ -n "$(ls -A "$ZMUX_ROOT/themes/iterm2" 2>/dev/null)" ]]; then
        printf "\n"
        $GUM style --foreground "$ZMUX_INFO" --bold --margin "0 2" "iterm2-color-schemes"
        local count=0
        for f in "$ZMUX_ROOT/themes/iterm2"/*; do
            [[ -f "$f" ]] || continue
            local name=$(basename "$f")
            [[ -n "${seen[$name]}" ]] && continue
            ((count++))
        done
        printf "  %d additional themes\n" "$count"
    fi
}

# ══════════════════════════════════════════
# VERSION
# ══════════════════════════════════════════
zmux_version() {
    printf "zmux %s\n" "$ZMUX_VERSION"
    printf "root:   %s\n" "$ZMUX_ROOT"
    printf "theme:  %s\n" "$ZMUX_THEME_NAME"
    printf "status: %s\n" "$ZMUX_STATUS_PRESET"
}

# ══════════════════════════════════════════
# DASHBOARD — inside tmux
# ══════════════════════════════════════════
dashboard() {
    clear
    local current=$(tmux display-message -p '#S')
    local current_dir=$(tmux display-message -p '#{pane_current_path}')
    current_dir="${current_dir/#$HOME/~}"

    # ── Compact header ──
    printf "\n"
    printf "  $($GUM style --foreground "$ZMUX_ACCENT" --bold "zmux")  $($GUM style --foreground "$ZMUX_DIM" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")\n"

    # ── Current context (one line) ──
    local tab_pills=""
    while IFS= read -r wline; do
        local wname=$(echo "$wline" | cut -d'|' -f1)
        local wactive=$(echo "$wline" | cut -d'|' -f2)
        local wcmd=$(echo "$wline" | cut -d'|' -f3)
        if [[ "$wactive" == "1" ]]; then
            tab_pills+="$($GUM style --foreground "$ZMUX_ACCENT" --bold "[$wname:$wcmd]") "
        else
            tab_pills+="$($GUM style --foreground "$ZMUX_DIM" "$wname") "
        fi
    done < <(tmux list-windows -F '#{window_name}|#{window_active}|#{pane_current_command}' 2>/dev/null)

    printf "  $($GUM style --foreground "$ZMUX_ACCENT" --bold "◆ $current")  $($GUM style --foreground "$ZMUX_DIM" "$current_dir")  $tab_pills\n"
    printf "  $($GUM style --foreground "$ZMUX_DIM" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")\n"

    # ── Session list ──
    local has_named=false has_tmp=false

    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        [[ "$name" == tmp-* ]] && continue
        if ! $has_named; then
            printf "  $($GUM style --foreground "$ZMUX_INFO" --bold "sessions")\n"
            has_named=true
        fi
        local is_current="false"
        [[ "$name" == "$current" ]] && is_current="true"
        printf "  $(render_session_line "$name" "$is_current")\n"
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort)

    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        [[ "$name" != tmp-* ]] && continue
        if ! $has_tmp; then
            $has_named && printf "\n"
            printf "  $($GUM style --foreground "$ZMUX_DIM" "temporary")\n"
            has_tmp=true
        fi
        local is_current="false"
        [[ "$name" == "$current" ]] && is_current="true"
        printf "  $(render_session_line "$name" "$is_current")\n"
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort -t- -k2 -n)

    printf "  $($GUM style --foreground "$ZMUX_DIM" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")\n"

    # ── Action picker ──
    local action=$($GUM choose \
        --cursor "  ▸ " \
        --cursor.foreground "$ZMUX_ACCENT" \
        --selected.foreground "$ZMUX_FG" \
        --item.foreground "$ZMUX_MUTED" \
        --header "  $($GUM style --foreground "$ZMUX_INFO" "s")$($GUM style --foreground "$ZMUX_DIM" "witch") $($GUM style --foreground "$ZMUX_SUCCESS" "n")$($GUM style --foreground "$ZMUX_DIM" "ew") $($GUM style --foreground "$ZMUX_META" "t")$($GUM style --foreground "$ZMUX_DIM" "mpl") $($GUM style --foreground "$ZMUX_SPECIAL" "m")$($GUM style --foreground "$ZMUX_DIM" "ove") $($GUM style --foreground "$ZMUX_HIGHLIGHT" ",")$($GUM style --foreground "$ZMUX_DIM" "name") $($GUM style --foreground "$ZMUX_HIGHLIGHT" ".")$($GUM style --foreground "$ZMUX_DIM" "tab") $($GUM style --foreground "$ZMUX_ERROR" "x")$($GUM style --foreground "$ZMUX_DIM" "kill") $($GUM style --foreground "$ZMUX_MUTED" "p")$($GUM style --foreground "$ZMUX_DIM" "rvw")" \
        --height 13 \
        "s  switch session" \
        "n  new session" \
        "t  new from template" \
        "m  move tab → session" \
        ",  rename session" \
        ".  rename tab" \
        "p  preview session" \
        "x  kill session" \
        "w  kill tab" \
        "T  theme" \
        "c  cleanup tmp" \
        "q  quit")

    case "$action" in
        s*)  action_switch ;;
        n*)  action_new_session ;;
        t*)  action_new_from_template ;;
        m*)  action_move_tab ;;
        ,*)  action_rename_session ;;
        .*)  action_rename_tab ;;
        p*)  action_preview ;;
        x*)  action_kill_session ;;
        w*)  action_kill_tab ;;
        T*)  action_theme ;;
        c*)  cleanup_tmp; success "cleaned up tmp sessions" ;;
        q*)  return 0 ;;
    esac
}

# ══════════════════════════════════════════
# OUTSIDE TMUX — session picker
# ══════════════════════════════════════════
outside_picker() {
    cleanup_tmp
    clear

    # ── Logo (compact) ──
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" '░█████████ ░█████████████  ░██    ░██ ░██    ░██'
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" '     ░███  ░██   ░██   ░██ ░██    ░██  ░██  ░██'
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" '   ░███    ░██   ░██   ░██ ░██    ░██   ░█████'
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" ' ░███      ░██   ░██   ░██ ░██   ░███  ░██  ░██'
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" '░█████████ ░██   ░██   ░██  ░█████░██ ░██    ░██'
    printf "  $($GUM style --foreground "$ZMUX_DIM" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")\n"

    # ── Session list ──
    local has_sessions=false

    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        [[ "$name" == tmp-* ]] && continue
        if ! $has_sessions; then
            printf "  $($GUM style --foreground "$ZMUX_INFO" --bold "sessions")\n"
            has_sessions=true
        fi
        printf "  $(render_session_line "$name" "false")\n"
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort)

    local has_tmp=false
    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        [[ "$name" != tmp-* ]] && continue
        if ! $has_tmp; then
            $has_sessions && printf "\n"
            printf "  $($GUM style --foreground "$ZMUX_DIM" "temporary")\n"
            has_tmp=true
        fi
        printf "  $(render_session_line "$name" "false")\n"
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}' 2>/dev/null | sort -t- -k2 -n)

    if ! $has_sessions && ! $has_tmp; then
        printf "  $($GUM style --foreground "$ZMUX_DIM" "no sessions")\n"
    fi

    printf "  $($GUM style --foreground "$ZMUX_DIM" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")\n"

    # ── Picker ──
    local items=()
    items+=("+ new session")
    items+=("+ new from template")

    while IFS= read -r line; do
        local name=$(echo "$line" | cut -d'|' -f1)
        local wins=$(echo "$line" | cut -d'|' -f2)
        local attached=$(echo "$line" | cut -d'|' -f3)
        local icon="○"
        [[ "$attached" == "1" ]] && icon="●"
        local win_names=$(tmux list-windows -t "$name" -F '#{window_name}' 2>/dev/null | tr '\n' ',' | sed 's/,$//')
        items+=("$icon $name  ${wins}w [$win_names]")
    done < <(tmux list-sessions -F '#{session_name}|#{session_windows}|#{session_attached}' 2>/dev/null | sort)

    local picked=$($GUM filter \
        --placeholder "search or create..." \
        --prompt "  ▸ " \
        --prompt.foreground "$ZMUX_ACCENT" \
        --indicator.foreground "$ZMUX_ACCENT" \
        --match.foreground "$ZMUX_INFO" \
        --text.foreground "$ZMUX_FG" \
        --height $((${#items[@]} + 2)) \
        "${items[@]}")

    [[ -z "$picked" ]] && exit 0

    case "$picked" in
        "+ new session")       action_new_session ;;
        "+ new from template") action_new_from_template ;;
        *)
            local name=$(echo "$picked" | sed 's/^[●○] //' | awk '{print $1}')
            exec tmux attach -t "$name"
            ;;
    esac
}

# ══════════════════════════════════════════
# BAR PRESET
# ══════════════════════════════════════════
_bar_preview_line() {
    local p="$1"
    local a=$(zmux_ansi "$ZMUX_ACCENT")
    local d=$(zmux_ansi "$ZMUX_DIM")
    local m=$(zmux_ansi "$ZMUX_MUTED")
    local fg=$(zmux_ansi "$ZMUX_FG")
    local r=$'\033[0m'
    local b=$'\033[1m'
    local sbg=$'\033[48;2;'"$((16#${ZMUX_SURFACE:1:2}));$((16#${ZMUX_SURFACE:3:2}));$((16#${ZMUX_SURFACE:5:2}))"'m'
    local abg=$'\033[48;2;'"$((16#${ZMUX_ACCENT:1:2}));$((16#${ZMUX_ACCENT:3:2}));$((16#${ZMUX_ACCENT:5:2}))"'m'
    local bgfg=$'\033[38;2;'"$((16#${ZMUX_BG:1:2}));$((16#${ZMUX_BG:3:2}));$((16#${ZMUX_BG:5:2}))"'m'

    local mark=" "
    [[ "$p" == "$ZMUX_STATUS_PRESET" ]] && mark="●"

    case "$p" in
        default)
            printf "${a}${mark}${r} ${fg}${b}default  ${r} ${sbg}${abg}${bgfg}${b} main ${r}${sbg}${a}${r}${sbg} ${d}1 shell ${d}│${a}${b} 2 edit ${r}${sbg}${d}│ 3 git  ${d}ctrl+space ${m}12:30${r}"
            ;;
        minimal)
            printf "${a}${mark}${r} ${fg}${b}minimal  ${r} ${sbg}${a}${b} main ${r}${sbg}${d}│${r}${sbg} ${d}shell  ${fg}${b}edit${r}${sbg}  ${d}git${r}${sbg}                  ${d}12:30${r}"
            ;;
        powerline)
            printf "${a}${mark}${r} ${fg}${b}powerline${r} ${sbg}${abg}${bgfg}${b} main ${r}${sbg}${a}${r}${sbg} ${d}1 shell ${a} 2 edit ${r}${sbg}${a}${r}${sbg}${d} 3 git  ${d}12:30 ${abg}${bgfg}${b} Mar 15 ${r}"
            ;;
        blocks)
            printf "${a}${mark}${r} ${fg}${b}blocks   ${r} ${sbg}${a}${b} [main] ${r}${sbg}${d}[1:shell] ${a}${b}[2:edit]${r}${sbg} ${d}[3:git]${r}${sbg}          ${d}[12:30]${r}"
            ;;
    esac
}

action_bar_set() {
    local preset="$1"
    if [[ -z "$preset" ]]; then
        local items=()
        for p in default minimal powerline blocks; do
            items+=("$(_bar_preview_line "$p")")
        done

        local picked
        picked=$(printf '%s\n' "${items[@]}" | $GUM choose \
            --no-strip-ansi \
            --cursor "▸ " \
            --cursor.foreground "$ZMUX_ACCENT" \
            --header "  bar preset:" \
            --header.foreground "$ZMUX_ACCENT" \
            --height 6)
        [[ -z "$picked" ]] && return 0

        # Extract preset name (second field after the marker)
        preset=$(echo "$picked" | sed 's/\x1b\[[0-9;]*m//g' | awk '{print $2}')
    fi

    case "$preset" in
        default|minimal|powerline|blocks) ;;
        *) fail "unknown preset: $preset (default, minimal, powerline, blocks)"; return 1 ;;
    esac

    local conf="${HOME}/.zmux.conf"
    if [[ -f "$conf" ]] && grep -q '^status' "$conf" 2>/dev/null; then
        sed -i "s|^status = .*|status = $preset|" "$conf"
    elif [[ -f "$conf" ]]; then
        echo "status = $preset" >> "$conf"
    fi

    if [[ -n "$TMUX" ]]; then
        "$ZMUX_ROOT/bin/zmux0-apply-theme"
    fi
    success "bar → $preset"
}

# ══════════════════════════════════════════
# HELP
# ══════════════════════════════════════════
zmux_help() {
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --bold --margin "0 2" "zmux $ZMUX_VERSION"
    printf "\n"
    $GUM style --foreground "$ZMUX_FG" --margin "0 2" "usage:"
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "session picker (outside tmux) / dashboard (inside)"
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux theme"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "browse and switch themes"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux theme set <name>"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "set theme directly"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux theme list"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "list available themes"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux theme sync"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "pull theme from default sync target"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux theme pull <target>"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "pull from ghostty or nvim"
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux bar"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "pick status bar preset with previews"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux bar <preset>"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "set preset (default, minimal, powerline, blocks)"
    printf "\n"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux init"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "first-time setup wizard"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux version"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "print version and config info"
    $GUM style --foreground "$ZMUX_ACCENT" --margin "0 4" "zmux help"
    $GUM style --foreground "$ZMUX_DIM" --margin "0 6" "this help"
    printf "\n"
}

# ══════════════════════════════════════════
# ENTRY POINT — CLI routing
# ══════════════════════════════════════════
case "${1:-}" in
    theme)
        case "${2:-}" in
            set)    action_theme_set "$3" ;;
            list)   action_theme_list ;;
            sync)
                source "$ZMUX_ROOT/lib/sync.sh"
                action_theme_sync
                ;;
            pull)
                source "$ZMUX_ROOT/lib/sync.sh"
                action_theme_pull "$3"
                ;;
            *)      action_theme ;;
        esac
        ;;
    bar)
        action_bar_set "${2:-}"
        ;;
    init)
        source "$ZMUX_ROOT/lib/init.sh"
        zmux_init
        ;;
    version|--version|-v)
        zmux_version
        ;;
    help|--help|-h)
        zmux_help
        ;;
    *)
        if [[ -n "$TMUX" ]]; then
            dashboard
        else
            outside_picker
        fi
        ;;
esac
